{
  "compilerOptions": {
    "esModuleInterop": true,
    "incremental": true,
    "lib": ["ES2022", "ES6", "DOM"],
    "module": "CommonJS",
    "noErrorTruncation": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": false,
    "target": "ES6",
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "package.json"]
}
